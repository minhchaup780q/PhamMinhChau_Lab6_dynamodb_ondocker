<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chỉnh sửa sản phẩm -
        <%= p.name %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f7f6;
        }
        
        .edit-container {
            max-width: 600px;
            margin-top: 50px;
        }
        
        .card {
            border: none;
            border-radius: 15px;
        }
        
        .form-label {
            font-weight: 600;
            color: #495057;
        }
        
        .img-preview {
            border: 2px dashed #dee2e6;
            padding: 10px;
            border-radius: 10px;
            background-color: #fff;
        }
        
        .btn-success {
            border-radius: 8px;
            padding: 10px 20px;
            font-weight: 600;
        }
        
        .btn-secondary {
            border-radius: 8px;
            padding: 10px 20px;
        }
        
        .current-img {
            object-fit: cover;
            border-radius: 5px;
        }
    </style>
</head>

<body>
    <div class="container edit-container mb-5">
        <div class="card shadow-lg">
            <div class="card-header bg-success text-white py-3" style="border-radius: 15px 15px 0 0;">
                <h4 class="mb-0 text-center">Chỉnh Sửa Sản Phẩm</h4>
            </div>
            <div class="card-body p-4">
                <form action="/update" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="id" value="<%= p.id %>">
                    <input type="hidden" name="old_image" value="<%= p.url_image %>">

                    <div class="mb-3">
                        <label class="form-label">Tên sản phẩm</label>
                        <input type="text" name="name" value="<%= p.name %>" class="form-control form-control-lg" placeholder="Nhập tên sản phẩm" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giá bán (VND)</label>
                            <input type="number" name="price" value="<%= p.price %>" class="form-control" min="1" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Số lượng tồn kho</label>
                            <input type="number" name="unit_in_stock" value="<%= p.unit_in_stock %>" class="form-control" min="1" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label d-block">Hình ảnh sản phẩm</label>
                        <div class="img-preview mb-2 text-center">
                            <small class="text-muted d-block mb-2">Ảnh hiện tại:</small>
                            <img src="<%= p.url_image %>" width="120" height="120" class="current-img shadow-sm border">
                        </div>
                        <small class="text-muted">Chọn ảnh mới nếu muốn thay đổi:</small>
                        <input type="file" name="url_image" class="form-control mt-1">
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/" class="btn btn-secondary me-md-2">Hủy bỏ</a>
                        <button type="submit" class="btn btn-success px-5">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>

        <p class="text-center text-muted mt-4 small">
            ID Sản phẩm: <code class="text-dark"><%= p.id %></code>
        </p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>